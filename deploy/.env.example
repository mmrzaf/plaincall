# PlainCall image tag
PLAINCALL_VERSION=0.2.0-alpha.2

# DNS
# call.example.com: ArvanCloud proxy enabled
# rtc.example.com:  ArvanCloud DNS-only, proxy disabled
PLAINCALL_DOMAIN=call.example.com
PLAINCALL_RTC_DOMAIN=rtc.example.com

# Pin the LiveKit server image.
LIVEKIT_VERSION=v1.13.1

# Generate these with: ./scripts/generate-secrets.sh
LIVEKIT_API_KEY=replace-with-generated-key
LIVEKIT_API_SECRET=replace-with-generated-secret
PLAINCALL_SECRET_KEY=replace-with-generated-room-signing-secret

# Optional overrides
PLAINCALL_ROOM_TTL=24h
PLAINCALL_TOKEN_TTL=30m

# Optional embedded TURN fallback. Leave disabled until strict-network tests
# show failed joins. Put trusted tls.crt and tls.key files in deploy/turn-certs/.
# Start with: docker compose --env-file .env -f compose.yml -f compose.turn.yml up -d
LIVEKIT_TURN_ENABLED=false
PLAINCALL_TURN_DOMAIN=turn.example.com
LIVEKIT_TURN_UDP_PORT=443
LIVEKIT_TURN_TLS_PORT=5349
